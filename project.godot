; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Rikiki 2D"
run/main_scene="uid://b47yh3rjmhknp"
config/features=PackedStringArray("4.5", "C#", "Mobile")

[autoload]

Server="*res://Scripts/Server/ServerScript.cs"
GlobalScript="*res://Scripts/GlobalScript.cs"
Lobby="*res://Scripts/Server/LobbyScript.cs"

[display]

window/size/viewport_width=1344
window/size/viewport_height=756
window/stretch/mode="viewport"
window/stretch/aspect="expand"

[dotnet]

project/assembly_name="Rikiki 2D"

[file_customization]

folder_colors={
"res://Scenes/": "red",
"res://Scripts/": "blue",
"res://Sounds/": "teal",
"res://Textures/": "yellow"
}

[input_devices]

pointing/emulate_touch_from_mouse=true

[rendering]

renderer/rendering_method="mobile"
